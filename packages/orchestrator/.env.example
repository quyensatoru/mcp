MONGO_URI=mongodb://localhost:27017/mida_orchestrator

MCP_TRANSPORT=stdio
PORT=3100
JWT_SECRET=change-me-at-least-16-chars

MONGO_TARGETS=[{"cluster":"shard1","conn":"mongodb://user:pass@host1:27017"},{"cluster":"shard2","conn":"mongodb://user:pass@host2:27017"}]
# rabbit dùng management HTTP API → conn là URL management (mặc định port 15672), KHÔNG phải amqp.
RABBIT_TARGETS=[{"cluster":"prod","conn":"http://user:pass@rabbit-prod:15672"}]
REDIS_TARGETS=[{"cluster":"cache","conn":"redis://redis-cache:6379"}]
