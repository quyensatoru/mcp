# Console API + dashboard server
CONSOLE_PORT=4000
# Bearer token for /api/* — leave blank for open access in dev
CONSOLE_TOKEN=
# Shared with the agent; falls back to packages/agent/.env if unset here
MONGO_URI=
# 32+ char passphrase to encrypt secrets at rest (set BEFORE first seed). Blank = plaintext.
CONSOLE_MASTER_KEY=
# Cache TTL (ms) for cross-process config reads on standalone Mongo
CONFIG_TTL_MS=30000
# Optional: override path to the Claude Code native binary.
# Auto-resolved per platform (claude.exe on Windows, claude elsewhere) — only set to force a path.
CLAUDE_BIN=
VITE_ALLOW_HOST=
VITE_API_URL=

