{
    "name": "@mida/console",
    "version": "1.0.0",
    "description": "Mida Console — dynamic config control-plane (config layer, API server, dashboard)",
    "type": "module",
    "main": "src/config/index.js",
    "exports": {
        ".": "./src/config/index.js",
        "./server": "./src/index.js"
    },
    "scripts": {
        "seed": "node scripts/seed.js",
        "test": "node --test \"test/**/*.test.js\"",
        "dev": "node src/index.js",
        "start": "node src/index.js",
        "dev:web": "vite --config web/vite.config.js",
        "build:web": "vite build --config web/vite.config.js"
    },
