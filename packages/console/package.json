        "dotenv": "^17.4.2",
        "express": "^5.2.1",
        "mongoose": "^8.24.0",
        "ws": "^8.21.0",
        "zod": "^4.4.3"
    },
    "devDependencies": {
        "@monaco-editor/react": "^4.6.0",
        "@tailwindcss/vite": "^4.1.0",
        "@vitejs/plugin-react": "^4.3.0",
        "react": "^18.3.1",
        "react-dom": "^18.3.1",
        "react-markdown": "^10.1.0",
