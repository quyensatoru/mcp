{
    "name": "mida-rsa",
    "version": "1.0.0",
    "private": true,
    "description": "Mida RSA monorepo",
    "license": "ISC",
    "author": "quyenpv",
    "type": "module",
    "scripts": {
        "dev": "concurrently -n mcp,agent,console,web -c blue,green,magenta,cyan \"npm run dev --workspace=@mida/mcp\" \"npm run dev --workspace=@mida/agent\" \"npm run dev --workspace=@mida/console\" \"npm run dev:web --workspace=@mida/console\"",
        "dev:web": "npm run dev:web --workspace=@mida/console",
        "mcp": "pnpm --filter mida-mcp",
        "format": "prettier --write .",
        "format:check": "prettier --check .",
        "lint": "eslint packages"
    },
    "devDependencies": {
        "@eslint/js": "^9.5.0",
        "concurrently": "^10.0.3",
        "eslint": "^9.5.0",
        "eslint-plugin-react": "^7.37.0",
        "globals": "^15.6.0",
        "husky": "^9.0.11",
        "prettier": "^3.3.2"
    },
    "dependencies": {
        "dotenv": "^17.4.2",
        "express": "^5.2.1",
        "zod": "^4.4.3"
    },
    "workspaces": [
        "packages/*"
    ],
    "pnpm": {
        "supportedArchitectures": {
            "os": [
                "linux"
            ],
            "cpu": [
                "x64"
            ],
            "libc": [
                "glibc"
            ]
        }
    }
}
