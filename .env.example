# ── Server ──────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# "http" = StreamableHTTP qua Express (cần JWT_SECRET)
# "stdio" = local dev cho Claude Desktop / Claude Code (không cần JWT)
MCP_TRANSPORT=http
JWT_SECRET=change_me_at_least_32_chars_long

# ── MongoDB — Sharded (read-only) ────────────────────────────────────────────
PROXY_URI=mongodb://user:pass@proxy-host:27017/proxy
API_URI_1=mongodb://user:pass@api1-host:27017/api
API_URI_2=mongodb://user:pass@api2-host:27017/api
HM_URI_1=mongodb://user:pass@hm1-host:27017/heatmap
HM_URI_2=mongodb://user:pass@hm2-host:27017/heatmap

# ── MongoDB — Recorder backup (2 shard, cùng cấu trúc với api) ──────────────
RECORDER_URI_1=mongodb://user:pass@recorder1-host:27017/recorder
RECORDER_URI_2=mongodb://user:pass@recorder2-host:27017/recorder

# ── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379
CACHE_TTL=300

# ── Loki / Grafana ───────────────────────────────────────────────────────────
LOKI_URL=https://logs-prod-XXX.grafana.net
# Grafana Cloud: dùng LOKI_USER (instance ID) + LOKI_PASS (API key)
# Self-hosted: dùng LOKI_TOKEN (Bearer)
LOKI_USER=
LOKI_PASS=
LOKI_TOKEN=
LOKI_ORG_ID=

# ── Shopify ──────────────────────────────────────────────────────────────────
SHOPIFY_API_VERSION=2024-04

# ── App API nội bộ ───────────────────────────────────────────────────────────
APP_API_BASE_URL=https://api.getmida.com
APP_API_TOKEN=

# ── Firecrawl (chỉ dùng cho scripts/crawl-docs.js) ──────────────────────────
FIRECRAWL_API_KEY=fc-xxxxxxxxxxxx
MIDA_DOCS_URL=https://docs.getmida.com
