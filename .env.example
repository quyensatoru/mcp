PORT=3000
NODE_ENV=development

MCP_TRANSPORT=http
JWT_SECRET=change_me_at_least_32_chars_long

#MongoDB — Sharded (read-only)
PROXY_URI=mongodb://user:pass@proxy-host:27017/proxy
API_URI_1=mongodb://user:pass@api1-host:27017/api
API_URI_2=mongodb://user:pass@api2-host:27017/api
HM_URI_1=mongodb://user:pass@hm1-host:27017/heatmap
HM_URI_2=mongodb://user:pass@hm2-host:27017/heatmap
RECORDER_URI_1=mongodb://user:pass@recorder1-host:27017/recorder
RECORDER_URI_2=mongodb://user:pass@recorder2-host:27017/recorder

#Redis
REDIS_URL=redis://localhost:6379
CACHE_TTL=300

#Loki / Grafana
LOKI_URL=https://logs-prod-XXX.grafana.net
LOKI_USER=
LOKI_PASS=
LOKI_TOKEN=
LOKI_ORG_ID=

#Firecrawl
FIRECRAWL_API_KEY=fc-xxxxxxxxxxxx
MIDA_DOCS_URL=https://docs.getmida.com
